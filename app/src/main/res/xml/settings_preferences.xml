<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="@string/pref_category_appearance">
        <ListPreference
            app:key="theme"
            app:title="@string/pref_theme"
            app:entries="@array/theme_entries"
            app:entryValues="@array/theme_values"
            app:defaultValue="system"
            app:useSimpleSummaryProvider="true" />
        <ListPreference
            app:key="app_language"
            app:title="@string/pref_language"
            app:entries="@array/language_entries"
            app:entryValues="@array/language_values"
            app:defaultValue="system"
            app:useSimpleSummaryProvider="true" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/pref_category_notifications">
        <SwitchPreferenceCompat
            app:key="vibrate_on_success"
            app:title="@string/pref_vibrate"
            app:defaultValue="true" />
        <SwitchPreferenceCompat
            app:key="sound_on_success"
            app:title="@string/pref_sound"
            app:defaultValue="false" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/pref_category_data">
        <Preference
            app:key="manage_routers"
            app:title="@string/pref_manage_routers"
            app:icon="@drawable/ic_router" />
        <Preference
            app:key="clear_history"
            app:title="@string/pref_clear_history"
            app:icon="@drawable/ic_delete" />
        <Preference
            app:key="export_db"
            app:title="@string/pref_export_db"
            app:icon="@drawable/ic_export" />
    </PreferenceCategory>

    <PreferenceCategory app:title="@string/pref_category_about">
        <Preference
            app:key="version"
            app:title="@string/pref_version"
            app:icon="@drawable/ic_info" />
        <Preference
            app:key="github"
            app:title="@string/pref_github"
            app:icon="@drawable/ic_github" />
    </PreferenceCategory>
</PreferenceScreen>
