<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0A0015">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal"
        android:layoutDirection="rtl">

        <ImageView
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="24dp"
            android:padding="32dp"
            android:background="@drawable/bg_security_box"
            android:src="@drawable/ic_lock_purple"
            android:contentDescription="Lock Icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تم قفل البرنامج بشكل دائم"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="تم اكتشاف محاولة غير مصرح بها للوصول أو استخدام البرنامج.\nللحفاظ على أمان بياناتك، تم قفل البرنامج بشكل دائم."
            android:textColor="#DDDDDD"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="32dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_security_box"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">
            
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_info_purple"
                android:layout_marginEnd="12dp"/>
                
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:text="لا يمكن استخدام البرنامج بعد الآن. يرجى حذف التطبيق بالكامل وإعادة تثبيته من المصدر الرسمي." />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_uninstall"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_security_button"
            android:text="حذف التطبيق"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="بعد حذف التطبيق، يرجى إعادة تثبيته من الموقع الرسمي للحصول على نسخة آمنة."
            android:textColor="#8855FF"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="48dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_info_purple"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تحتاج إلى مساعدة؟\nتواصل معنا"
                android:textColor="#8855FF"
                android:textSize="12sp"
                android:gravity="start" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="المطور : MOHAMED"
            android:textColor="#DDDDDD"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>

</ScrollView>
