<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_custom_dialog"
    android:padding="20dp"
    android:layout_margin="16dp"
    android:gravity="center_horizontal">

    <!-- Icon Card Header -->
    <FrameLayout
        android:id="@+id/dialog_icon_container"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/bg_circle_blue"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/dialog_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_info"
            app:tint="@color/white"
            android:contentDescription="Dialog Icon" />
    </FrameLayout>

    <!-- Dialog Title -->
    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/auto_string_11"
        android:textColor="?attr/colorOnSurface"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="10dp" />

    <!-- Dialog Message -->
    <TextView
        android:id="@+id/dialog_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/auto_string_12"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="14sp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="20dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutlineVariant"
        android:layout_marginBottom="16dp" />

    <!-- Action Buttons Container -->
    <LinearLayout
        android:id="@+id/dialog_buttons_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Positive Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_positive"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/auto_string_13"
            app:backgroundTint="?attr/colorPrimary"
            android:textColor="?attr/colorOnPrimary"
            android:layout_marginBottom="8dp" />

        <!-- Negative Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_negative"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/auto_string_14"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Neutral Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_neutral"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/auto_string_15"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
