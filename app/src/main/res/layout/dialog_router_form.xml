<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tv_dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ملف تعريف جهاز جديد"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- 1. Name Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:hint="اسم الملف (مثال: مستخدم راوتر 1)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_router_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 2. Protocol -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <Spinner
                android:id="@+id/spinner_protocol"
                android:layout_width="match_parent"
                android:layout_height="54dp" />
        </LinearLayout>

        <!-- 3. IP or Hostname Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:hint="عنوان IP أو المضيف (IP / Hostname)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_ip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:text="192.168.1.1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 4. Path Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:hint="مسار صفحة تسجيل الدخول">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_login_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:text="/login" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 5. Selectors (Username / Password) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:hint="معرف حقل اسم المستخدم (CSS Selector)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_username_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:text="input[name='username']" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:hint="معرف حقل كود البطاقة (CSS Selector)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_password_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:text="input[name='password']" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:hint="معرف زر الإرسال / انتر">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_submit_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:text="input[type='submit']" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 6. Account default credentials -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:hint="اسم المستخدم الافتراضي">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_username"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 7. Indicators (Success / Failure) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:hint="مؤشر النجاح (كلمة بالصفحة)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_success_indicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:text="تم تسجيل الدخول بنجاح" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="مؤشر الفشل (كلمة بالصفحة)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_failure_indicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:text="اسم المستخدم أو كلمة المرور خاطئة" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="معرف زر تسجيل الخروج (اختياري)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_logout_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Form Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialog_btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="إلغاء الأمر"
                style="@style/Widget.Material3.Button.TextButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialog_btn_save"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="حفظ التعريف" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
