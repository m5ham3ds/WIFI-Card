<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.WiFiCardMasterPro" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary Brand Color (Elegant Deep Purple Accent) -->
        <item name="colorPrimary">@color/wifi_purple_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/wifi_purple_container</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <!-- Secondary Brand Color (Purple motif for active highlights) -->
        <item name="colorSecondary">@color/wifi_purple_primary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/wifi_purple_transparent</item>
        <item name="colorOnSecondaryContainer">@color/white</item>

        <!-- Tertiary Color (Warning / Ongoing Tests) -->
        <item name="colorTertiary">@color/warning_orange</item>
        <item name="colorOnTertiary">@color/black</item>

        <!-- Background & Surface Colors -->
        <item name="android:windowBackground">@color/light_background</item>
        <item name="android:colorBackground">@color/light_background</item>
        <item name="colorOnBackground">@color/light_text_primary</item>
        <item name="colorSurface">@color/light_surface</item>
        <item name="colorOnSurface">@color/light_text_primary</item>
        <item name="colorSurfaceVariant">@color/light_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/light_text_secondary</item>

        <!-- Outlines & Borders -->
        <item name="colorOutline">@color/light_border</item>
        <item name="colorOutlineVariant">@color/light_border</item>

        <!-- Custom Bottom Navigation Style -->
        <item name="bottomNavigationStyle">@style/Widget.App.BottomNavigationView</item>

        <!-- Error State -->
        <item name="colorError">@color/error_red</item>
        <item name="colorOnError">@color/white</item>

        <!-- Status Bar & Navigation Bar -->
        <item name="android:statusBarColor">@color/light_background</item>
        <item name="android:navigationBarColor">@color/light_surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
    </style>

    <style name="Theme.WiFiCardMasterPro.AppBarOverlay" parent="ThemeOverlay.Material3.ActionBar" />
    <style name="Theme.WiFiCardMasterPro.PopupOverlay" parent="ThemeOverlay.Material3.Light" />

    <style name="Widget.App.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="materialThemeOverlay">@style/ThemeOverlay.App.BottomNavigationView</item>
    </style>

    <style name="ThemeOverlay.App.BottomNavigationView" parent="">
        <item name="colorSecondaryContainer">@color/light_purple_transparent</item>
        <item name="colorOnSecondaryContainer">@color/wifi_purple_primary</item>
    </style>
</resources>
